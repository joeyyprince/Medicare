<%- include('../partials/header') %>
<h2 style="margin-bottom:20px;">Add New Patient</h2>
<% if (error) { %><p class="error"><%= error %></p><% } %>
<form method="POST" action="/admin/patients/create">
  <label>Full Name</label>
  <input type="text" name="name" required placeholder="Patient full name">
  <label>Email</label>
  <input type="email" name="email" required placeholder="Patient email">
  <label>Phone</label>
  <input type="text" name="phone" placeholder="Phone number">
  <label>Date of Birth</label>
  <input type="date" name="dateOfBirth">
  <label>Gender</label>
  <select name="gender">
    <option value="male">Male</option>
    <option value="female">Female</option>
    <option value="other">Other</option>
  </select>
  <label>Address</label>
  <input type="text" name="address" placeholder="Patient address">
  <label>Medical History</label>
  <textarea name="medicalHistory" rows="4" style="width:100%; padding:10px; border:1px solid #ddd; border-radius:4px;" placeholder="Any relevant medical history"></textarea>
  <label>Assign Doctor</label>
  <select name="assignedDoctor">
    <option value="">-- Select Doctor --</option>
    <% doctors.forEach(doctor => { %>
    <option value="<%= doctor._id %>"><%= doctor.name %></option>
    <% }) %>
  </select>
  <button type="submit" class="btn" style="margin-top:10px;">Add Patient</button>
  <a href="/admin/patients" style="margin-left:10px;">Cancel</a>
</form>
<%- include('../partials/footer') %>