<%- include('../partials/header') %>
<h2 style="margin-bottom:20px;">Patient Details</h2>
<% if (error) { %><p class="error"><%= error %></p><% } %>
<table style="width:100%; border-collapse:collapse; margin-bottom:30px;">
  <tr style="border-bottom:1px solid #ddd;">
    <td style="padding:10px; font-weight:bold;">Name</td>
    <td style="padding:10px;"><%= patient.name %></td>
  </tr>
  <tr style="border-bottom:1px solid #ddd;">
    <td style="padding:10px; font-weight:bold;">Email</td>
    <td style="padding:10px;"><%= patient.email %></td>
  </tr>
  <tr style="border-bottom:1px solid #ddd;">
    <td style="padding:10px; font-weight:bold;">Phone</td>
    <td style="padding:10px;"><%= patient.phone || 'N/A' %></td>
  </tr>
  <tr style="border-bottom:1px solid #ddd;">
    <td style="padding:10px; font-weight:bold;">Gender</td>
    <td style="padding:10px;"><%= patient.gender || 'N/A' %></td>
  </tr>
  <tr style="border-bottom:1px solid #ddd;">
    <td style="padding:10px; font-weight:bold;">Address</td>
    <td style="padding:10px;"><%= patient.address || 'N/A' %></td>
  </tr>
</table>

<h3 style="margin-bottom:15px;">Update Medical Notes</h3>
<form method="POST" action="/doctor/patients/<%= patient._id %>/notes">
  <textarea name="medicalHistory" rows="6" style="width:100%; padding:10px; border:1px solid #ddd; border-radius:4px;"><%= patient.medicalHistory || '' %></textarea>
  <button type="submit" class="btn" style="margin-top:10px;">Save Notes</button>
  <a href="/doctor/patients" style="margin-left:10px;">Back</a>
</form>
<%- include('../partials/footer') %>