<%- include('../partials/header') %>
<h2 style="margin-bottom:20px;">My Medical Record</h2>
<% if (patient) { %>
  <table style="width:100%; border-collapse:collapse;">
    <tr style="border-bottom:1px solid #ddd;">
      <td style="padding:10px; font-weight:bold;">Name</td>
      <td style="padding:10px;"><%= patient.name %></td>
    </tr>
    <tr style="border-bottom:1px solid #ddd;">
      <td style="padding:10px; font-weight:bold;">Email</td>
      <td style="padding:10px;"><%= patient.email %></td>
    </tr>
    <tr style="border-bottom:1px solid #ddd;">
      <td style="padding:10px; font-weight:bold;">Phone</td>
      <td style="padding:10px;"><%= patient.phone || 'N/A' %></td>
    </tr>
    <tr style="border-bottom:1px solid #ddd;">
      <td style="padding:10px; font-weight:bold;">Gender</td>
      <td style="padding:10px;"><%= patient.gender || 'N/A' %></td>
    </tr>
    <tr style="border-bottom:1px solid #ddd;">
      <td style="padding:10px; font-weight:bold;">Address</td>
      <td style="padding:10px;"><%= patient.address || 'N/A' %></td>
    </tr>
    <tr style="border-bottom:1px solid #ddd;">
      <td style="padding:10px; font-weight:bold;">Medical History</td>
      <td style="padding:10px;"><%= patient.medicalHistory || 'N/A' %></td>
    </tr>
    <tr style="border-bottom:1px solid #ddd;">
      <td style="padding:10px; font-weight:bold;">Assigned Doctor</td>
      <td style="padding:10px;"><%= patient.assignedDoctor ? patient.assignedDoctor.name : 'Not assigned yet' %></td>
    </tr>
  </table>
<% } else { %>
  <p>No medical record found. Please contact the admin.</p>
<% } %>
<%- include('../partials/footer') %>